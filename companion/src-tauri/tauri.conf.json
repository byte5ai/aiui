{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "aiui",
  "version": "0.1.1",
  "identifier": "de.byte5.aiui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "aiui",
        "width": 520,
        "height": 560,
        "minWidth": 520,
        "minHeight": 400,
        "maxWidth": 520,
        "maxHeight": 560,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
